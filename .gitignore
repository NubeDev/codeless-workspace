# Workspace-level ignores. Per-repo ignores live inside each repo
# (e.g. codeless/.gitignore). Do NOT add `bin/` here — the bundled
# mani binary is intentionally tracked.
#
# Inner repos (codeless/, terax-ai/ if cloned) ARE ignored at the
# workspace level. They are independent GitHub repos; the workspace
# only tracks shared tooling (mani.yaml, DOCS, bin/, vendored
# ai-runner/). Tracking them here would force a submodule/gitlink,
# which we explicitly do not want — see DOCS/MANI.md.

# Inner repos (independent histories — see comment above)
codeless/
terax-ai/

# Build outputs
target/
node_modules/
dist/
build/

# SQLite databases produced by codeless at runtime
*.db
*.db-journal
*.db-wal
*.db-shm

# Worktree dirs created by the codeless runtime
worktrees/

# Local codeless job/run data (runtime-generated, not shared)
.codeless/

# Secrets / local config
.env
.env.*
!.env.example

# OS junk
.DS_Store
Thumbs.db

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo

# Local agent / IDE state (per-developer, not shared)
.claude/

# Logs
*.log
audit.log*
hackline/.hackline-dev/gateway.pid
.gitignore
hackline/.hackline-dev/ui.pid
